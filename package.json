{
  "name": "lintranslator",
  "version": "0.1.2",
  "description": "Local Bubble Translator - macOS desktop app for text and image translation",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite --host 127.0.0.1 --port 1420",
    "dev": "tauri dev",
    "build:frontend": "vite build",
    "build": "tauri build",
    "build:mac": "tauri build --bundles app,dmg",
    "build:windows": "tauri build --bundles nsis,msi --target x86_64-pc-windows-msvc",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.5.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@unocss/preset-mini": "^66.7.0",
    "@unocss/preset-uno": "^66.7.0",
    "@unocss/vite": "^66.0.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "typescript": "^5.8.3",
    "unocss": "^66.7.0",
    "vite": "^6.3.2",
    "vue-tsc": "^2.2.10"
  }
}
